GROQ_API_KEY=
GATEKEEPER_MODEL=llama-3.1-8b-instant
EXTRACTION_MODEL=llama-3.1-8b-instant
OCR_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Optional — shows run history in LangGraph Studio (https://smith.langchain.com)
# 1. Sign up free at https://smith.langchain.com
# 2. Settings → API Keys → Create API Key
# 3. Paste below and restart: uv run langgraph dev --allow-blocking
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=plum-claims-adjudication
